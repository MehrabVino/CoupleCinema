generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MessageType {
  TEXT
  IMAGE
}

model Session {
  id         String    @id @default(cuid())
  code       String    @unique
  title      String
  hostName   String
  hostToken  String    @unique
  videoPath  String
  createdAt  DateTime  @default(now())
  messages   Message[]
}

model Message {
  id         String      @id @default(cuid())
  sessionId  String
  senderName String
  type       MessageType
  content    String?
  imagePath  String?
  createdAt  DateTime    @default(now())
  session    Session     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

